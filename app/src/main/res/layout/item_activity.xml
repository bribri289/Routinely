<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="56dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="@drawable/card_bg" android:padding="14dp" android:layout_marginBottom="6dp">
    <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/circle_green" android:layout_marginEnd="12dp"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_activity_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
        <TextView android:id="@+id/tv_activity_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_muted" android:textSize="11sp"/>
    </LinearLayout>
    <TextView android:id="@+id/tv_activity_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:fontFamily="sans-serif-medium"/>
</LinearLayout>