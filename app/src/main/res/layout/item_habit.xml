<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="@drawable/card_bg" android:orientation="vertical"
    android:padding="14dp" android:layout_marginBottom="10dp">

    <!-- Top row: streak badge | name+frequency | complete button | overflow -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">

        <!-- Lightning streak badge -->
        <LinearLayout android:id="@+id/badge_container" android:layout_width="44dp"
            android:layout_height="44dp" android:background="@drawable/card_bg2"
            android:gravity="center" android:orientation="vertical"
            android:layout_marginEnd="12dp">
            <TextView android:id="@+id/tv_streak_icon" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="&#9889;"
                android:textSize="14sp" android:gravity="center"/>
            <TextView android:id="@+id/tv_badge_streak" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_primary"
                android:textSize="11sp" android:fontFamily="sans-serif-medium" android:text="0"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Name + frequency -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tv_name" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="@color/text_primary"
                android:textSize="15sp" android:fontFamily="sans-serif-medium"
                android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/tv_frequency" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_muted"
                android:textSize="12sp" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Mark Complete button -->
        <TextView android:id="@+id/btn_quick_add" android:layout_width="80dp"
            android:layout_height="34dp" android:text="Done"
            android:textColor="#FFFFFF" android:textSize="12sp"
            android:gravity="center" android:background="@drawable/chip_bg_active"
            android:layout_marginEnd="8dp" android:fontFamily="sans-serif-medium"/>

        <!-- Overflow -->
        <TextView android:id="@+id/btn_overflow" android:layout_width="32dp"
            android:layout_height="32dp" android:text="&#8942;"
            android:textColor="@color/text_muted" android:textSize="18sp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Progress row: only visible when dailyTarget > 1 -->
    <LinearLayout android:id="@+id/progress_row" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal"
        android:gravity="center_vertical" android:layout_marginTop="10dp"
        android:visibility="gone">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <ProgressBar android:id="@+id/progress_habit"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="6dp"
                android:progressDrawable="@drawable/progress_habit"
                android:max="100" android:progress="0" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tv_today_count"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_muted" android:textSize="11sp" android:text="0 times"/>
        </LinearLayout>

        <TextView android:id="@+id/btn_count_add" android:layout_width="28dp"
            android:layout_height="28dp" android:text="+"
            android:textColor="@color/primary" android:textSize="18sp"
            android:gravity="center" android:layout_marginStart="10dp"/>
    </LinearLayout>
</LinearLayout>
