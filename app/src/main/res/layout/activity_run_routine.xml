<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Main content -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="16dp">
            <Button android:id="@+id/btn_back" android:layout_width="36dp" android:layout_height="36dp"
                android:text="←" android:background="@drawable/card_bg2"
                android:textColor="@color/text_secondary" android:padding="0dp" android:textSize="18sp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:id="@+id/tv_routine_name" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_primary"
                    android:textSize="20sp" android:fontFamily="sans-serif-medium"/>
                <TextView android:id="@+id/tv_routine_subtitle" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_muted"
                    android:textSize="13sp"/>
            </LinearLayout>
            <TextView android:id="@+id/btn_menu" android:layout_width="36dp" android:layout_height="36dp"
                android:text="⋯" android:textColor="@color/text_muted" android:textSize="20sp"
                android:gravity="center"/>
        </LinearLayout>

        <ProgressBar android:id="@+id/progress_bar" style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="4dp"
            android:progressTint="@color/orange" android:progressBackgroundTint="@color/bg3"/>

        <!-- Preview mode: step list -->
        <ScrollView android:id="@+id/preview_scroll" android:layout_width="match_parent"
            android:layout_height="0dp" android:layout_weight="1" android:scrollbars="none">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <!-- Empty state -->
                <TextView android:id="@+id/tv_empty" android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fill in your routine and organize the order."
                    android:textColor="@color/text_muted" android:textSize="16sp"
                    android:gravity="center" android:paddingTop="80dp" android:paddingBottom="80dp"
                    android:visibility="gone"/>

                <!-- Step list -->
                <LinearLayout android:id="@+id/steps_list" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical"/>
            </LinearLayout>
        </ScrollView>

        <!-- Run mode: timer ring (hidden in preview) -->
        <LinearLayout android:id="@+id/run_panel" android:layout_width="match_parent"
            android:layout_height="0dp" android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:padding="32dp" android:visibility="gone">
            <FrameLayout android:layout_width="180dp" android:layout_height="180dp"
                android:layout_gravity="center_horizontal" android:layout_marginBottom="32dp">
                <ProgressBar android:id="@+id/timer_ring" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="180dp" android:layout_height="180dp"
                    android:rotation="-90" android:progressTint="@color/orange"
                    android:progressBackgroundTint="@color/bg3" android:max="100"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_timer" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/orange"
                        android:textSize="42sp" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="remaining" android:textColor="@color/text_muted" android:textSize="12sp"/>
                </LinearLayout>
            </FrameLayout>
            <TextView android:id="@+id/tv_step_emoji" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="40sp" android:layout_marginBottom="12dp"/>
            <TextView android:id="@+id/tv_step_name" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_primary"
                android:textSize="22sp" android:fontFamily="sans-serif-medium"
                android:gravity="center" android:layout_marginBottom="12dp"/>
            <TextView android:id="@+id/tv_step_description" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="@color/text_muted"
                android:textSize="14sp" android:gravity="center" android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp"/>
            <LinearLayout android:id="@+id/habit_panel" android:layout_width="wrap_content"
                android:layout_height="40dp" android:background="@drawable/card_bg2"
                android:orientation="horizontal" android:gravity="center"
                android:padding="12dp" android:visibility="gone">
                <TextView android:id="@+id/tv_habit_name" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/green"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom action bar -->
        <LinearLayout android:id="@+id/action_bar" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
            <Button android:id="@+id/btn_complete" android:layout_width="match_parent"
                android:layout_height="56dp" android:background="@drawable/btn_primary_bg"
                android:textColor="@color/text_primary" android:textSize="16sp"
                android:fontFamily="sans-serif-medium" android:layout_marginBottom="10dp"
                android:visibility="gone"/>
            <!-- Start button shown in preview mode -->
            <Button android:id="@+id/btn_start_run" android:layout_width="match_parent"
                android:layout_height="56dp" android:text="▶  Start Routine"
                android:background="@drawable/btn_primary_bg" android:textColor="@color/text_primary"
                android:textSize="16sp" android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:visibility="gone"
                android:id="@+id/skip_pause_row">
                <Button android:id="@+id/btn_skip" android:layout_width="0dp"
                    android:layout_height="48dp" android:layout_weight="1" android:text="Skip"
                    android:background="@drawable/btn_secondary_bg"
                    android:textColor="@color/text_secondary" android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btn_pause" android:layout_width="0dp"
                    android:layout_height="48dp" android:layout_weight="1"
                    android:background="@drawable/btn_secondary_bg"
                    android:textColor="@color/text_secondary" android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- FAB + button (yellow, bottom center) -->
    <TextView android:id="@+id/fab_add_step" android:layout_width="56dp" android:layout_height="56dp"
        android:text="+" android:textColor="#000000" android:textSize="28sp"
        android:gravity="center" android:background="@drawable/circle_yellow"
        android:layout_gravity="bottom|center_horizontal" android:layout_marginBottom="96dp"
        android:elevation="6dp"/>

</FrameLayout>