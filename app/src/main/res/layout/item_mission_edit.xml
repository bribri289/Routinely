<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="@drawable/card_bg2" android:orientation="vertical"
    android:padding="14dp" android:layout_marginBottom="10dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
        <TextView android:id="@+id/tv_mission_icon" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/card_bg" android:textSize="22sp" android:gravity="center" android:layout_marginEnd="10dp"/>
        <TextView android:id="@+id/tv_mission_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/text_primary" android:textSize="15sp" android:fontFamily="sans-serif-medium"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Required" android:textColor="@color/text_muted" android:textSize="12sp" android:layout_marginEnd="6dp"/>
        <Switch android:id="@+id/sw_required" android:layout_width="wrap_content" android:layout_height="wrap_content" android:thumbTint="@color/primary" android:trackTint="#3F3F46" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_remove_mission" android:layout_width="32dp" android:layout_height="32dp" android:text="✕" android:background="@drawable/card_bg" android:textColor="@color/red" android:textSize="14sp" android:padding="0dp"/>
    </LinearLayout>
    <LinearLayout android:id="@+id/mission_config" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
</LinearLayout>